<Base title="KVKK Aydınlatma Metni · DijitAs" description="DijitAs KVKK Aydınlatma Metni — sürüm 0.2 taslak.">

<style>
  .draft-banner { background: #fff8e1; border: 1px solid #f59e0b; border-radius: 8px; padding: 14px 20px; font-size: 13.5px; color: #92400e; margin-bottom: 32px; display:flex; gap:10px; align-items:flex-start; }
