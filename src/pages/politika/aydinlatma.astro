  .prose { max-width: 760px; }
  .prose h2 { font: 700 20px var(--font-sans); color: var(--fg-1); margin: 40px 0 14px; letter-spacing: -0.02em; border-bottom: 1px solid var(--border-1); padding-bottom: 10px; }
  .prose h3 { font: 600 15px var(--font-sans); color: var(--fg-1); margin: 24px 0 8px; }
  .prose p, .prose li { font-size: 14.5px; color: var(--fg-2); line-height: 1.7; }
  .prose ul { padding-left: 20px; margin: 10px 0; }
  .prose li { margin: 4px 0; }
  .prose .meta { font-size:13px; color:var(--fg-3); margin-bottom:28px; }
  .prose strong { color: var(--fg-1); }
  .data-table { width:100%; border-collapse:collapse; border:1px solid var(--border-1); border-radius: 8px; overflow:hidden; background:#fff; margin: 16px 0 24px; }
