---
import '../styles/colors.css';
import '../styles/site.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'urun' | 'skills' | 'fiyat' | 'case-studies' | 'blog' | 'kvkk' | 'hakkimizda' | 'iletisim' | null;
  pageClass?: string;
}

const {
  title,
  description = "DijitAs — KOBİ'ler için yapay zekâ operasyon asistanı. Ofis cihazında çalışır, veri Türkiye'de kalır.",
  activeNav = null,
  pageClass = ''
} = Astro.props;

const B = import.meta.env.BASE_URL;
const u = (p: string) => (B + p.replace(/^\//, '')).replace(/\/{2,}/g, '/');

const navItems: { href: string; label: string; key: NonNullable<Props['activeNav']> }[] = [
  { href: u('/urun'), label: 'Ürün', key: 'urun' },
  { href: u('/skills'), label: "Skill'ler", key: 'skills' },
  { href: u('/fiyat'), label: 'Fiyat', key: 'fiyat' },
  { href: u('/case-studies'), label: 'Vakalar', key: 'case-studies' },
  { href: u('/blog'), label: 'Blog', key: 'blog' },
  { href: u('/kvkk-guvenlik'), label: 'KVKK & Güvenlik', key: 'kvkk' },
  { href: u('/hakkimizda'), label: 'Hakkımızda', key: 'hakkimizda' }
];
---
<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={u('/favicon.svg')} />
  <link rel="alternate icon" type="image/png" href={u('/logo.png')} />
  <title>{title}</title>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:site_name" content="DijitAs" />
  <meta name="theme-color" content="#002058" />
  <script src="https://unpkg.com/lucide@latest" is:inline></script>
</head>
<body class={pageClass}>

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-logo" href={u('/')}><img src={u('/logo.png')} alt="DijitA" /></a>
    <div class="nav-links">
      {navItems.map(({ href, label, key }) => (
        <a href={href} class={activeNav === key ? 'active' : ''}>{label}</a>
      ))}
    </div>
    <div class="nav-cta">
      <a class="btn btn-ghost btn-sm" href={u('/iletisim')}>İletişim</a>
      <a class="btn btn-primary btn-sm" href={u('/iletisim')}>Demo talep et</a>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<footer class="site-foot">
  <div class="shell">
    <div class="footer-grid">
      <div>
        <div class="foot-logo"><img src={u('/logo.png')} alt="DijitA" /></div>
        <p class="foot-note">DijitAs · KOBİ'ler için yapay zekâ operasyon asistanı. Ofis cihazında çalışır, veri Türkiye'de kalır.</p>
      </div>
      <div>
        <h5>Ürün</h5>
        <a href={u('/urun')}>Nasıl çalışır</a>
        <a href={u('/skills')}>Skill'ler</a>
        <a href={u('/fiyat')}>Fiyat</a>
        <a href={u('/iletisim')}>Demo talep et</a>
      </div>
      <div>
        <h5>Güven</h5>
        <a href={u('/kvkk-guvenlik')}>KVKK &amp; Güvenlik</a>
        <a href="#">Aydınlatma metni</a>
        <a href="#">Çerez politikası</a>
        <a href="#">Kullanım koşulları</a>
      </div>
      <div>
        <h5>Şirket</h5>
        <a href={u('/hakkimizda')}>Hakkımızda</a>
        <a href={u('/case-studies')}>Vakalar</a>
        <a href={u('/blog')}>Blog</a>
        <a href={u('/iletisim')}>İletişim</a>
      </div>
      <div>
        <h5>İletişim</h5>
        <a href="mailto:iletisim@dijitapro.com.tr">iletisim@dijitapro.com.tr</a>
        <a href="#">+90 216 000 00 00</a>
        <a href="#">İstanbul, Türkiye</a>
      </div>
    </div>
    <div class="foot-bottom">
      <div>© 2026 DijitA Yazılım A.Ş. · dijitapro.com.tr</div>
      <div>v0.1.0 · built in Istanbul</div>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ BASE: B }}>
  // GitHub Pages base prefix: rewrite absolute hrefs/srcs that live under app root but were authored with "/".
  (function () {
    if (!BASE || BASE === '/') return;
    function fix(attr, sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        var v = el.getAttribute(attr);
        if (!v || v.indexOf(BASE) === 0 || v.indexOf('//') === 0 || v.indexOf('mailto:') === 0 || v.indexOf('#') === 0) return;
        if (v.charAt(0) === '/') el.setAttribute(attr, BASE + v.slice(1));
      });
    }
    function run() { fix('href', 'a[href^="/"]'); fix('src', 'img[src^="/"]'); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
  })();
  if (window.lucide) window.lucide.createIcons();
</script>

</body>
</html>
